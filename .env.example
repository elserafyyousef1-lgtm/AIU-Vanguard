# ═══════════════════════════════════════════════════════════
# AIU CS HUB — Environment Variables
# Copy this to .env.local and fill in your values.
# Only NEXT_PUBLIC_* vars reach the browser. The AI keys below are
# SERVER-ONLY — never prefix them with NEXT_PUBLIC.
# ═══════════════════════════════════════════════════════════

# ── Supabase (client + server) ─────────────────────────────
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ── AI (server-only — never exposed to the browser) ────────
# Gemini: powers the free AI tutor + RAG embeddings. REQUIRED for the tutor.
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here

# Anthropic: powers the advanced "Pro" tutor. OPTIONAL.
# Get from: https://console.anthropic.com/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── App ────────────────────────────────────────────────────
# Public base URL of the deployment (used for absolute links).
NEXT_PUBLIC_APP_URL=http://localhost:3000
